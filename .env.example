# Database
DATABASE_URL=postgresql://intellidocs:intellidocs_dev_password@localhost:5432/intellidocs_db

# Redis
REDIS_URL=redis://localhost:6379

# MinIO Storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_password
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET_NAME=intellidocs-documents

# Ollama LLM (Local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Groq API (Cloud LLM Backup - Optional)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3-8b-chat

# Google Gemini API (LLM Backup - Optional)
GOOGLE_API_KEY=your_google_api_key_here

# JWT Auth
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRATION=7d

# Application
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# Logging
LOG_LEVEL=debug

# File Upload
MAX_FILE_SIZE=52428800  # 50MB in bytes
ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg
